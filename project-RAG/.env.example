# Copy this file to .env and fill in your actual values

# Groq API Key - Get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Endee Vector Database URL (preferred if you know the full URL)
ENDEE_URL=http://localhost:8080

# Optional: Endee host:port (used by Render internal networking)
# ENDEE_HOSTPORT=endee-vector-db:8080

# Optional: Endee auth token (only if Endee runs with NDD_AUTH_TOKEN)
# ENDEE_AUTH_TOKEN=

# Index name
INDEX_NAME=RAGSYS
